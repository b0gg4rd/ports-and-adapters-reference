### Case 06: Failure - Should return 400 when a5 is a past date
POST {{host}}/api/v1/payments
Content-Type: application/json

{
  "a1": "payer-773899273774",
  "a2": "payee-998877665544",
  "a3": 100.00,
  "a5": "2000-01-01T00:00:00"
}

> {%
client.test("Should return 400 when a5 is a past date", function() {
    client.assert(response.status === 400, "Expected status 400 but got " + response.status);
});
%}
