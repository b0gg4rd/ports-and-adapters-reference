<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="console" target="SYSTEM_OUT">
      <JsonTemplateLayout>
        <EventTemplate><![CDATA[
        {
          "timestamp": {
            "$resolver": "timestamp",
            "pattern": {
              "format": "yyyy-MM-dd'T'HH:mm:ss.SSSXXX",
              "timeZone": "UTC"
            }
          },
          "level": {
            "$resolver": "level",
            "field": "name"
          },
          "logger": {
            "$resolver": "logger",
            "field": "name"
          },
          "thread": {
            "$resolver": "thread",
            "field": "name"
          },
          "trace_id": {
            "$resolver": "mdc",
            "key": "trace-id"
          },
          "message": {
            "$resolver": "message",
            "stringified": true
          },
          "exception": {
            "$resolver": "exception",
            "field": "stackTrace",
            "stackTrace": {
              "stringified": true
            }
          }
        }
        ]]></EventTemplate>
      </JsonTemplateLayout>
    </Console>
  </Appenders>
  <Loggers>
    <Logger name="${project.groupId}" level="${logger.app.level}" includeLocation="false" additivity="false">
      <AppenderRef ref="console" />
    </Logger>
    <Root level="${logger.root.level}" includeLocation="false">
      <AppenderRef ref="console" />
    </Root>
  </Loggers>
</Configuration>
